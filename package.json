{
  "name": "tradevaultx",
  "version": "1.0.0",
  "description": "TradeVaultX - Trading Journal by Milan",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.tradevaultx.app",
    "productName": "TradeVaultX",
    "publish": {
      "provider": "github",
      "owner": "solsuccess",
      "repo": "TradeVaultX"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "TradeVault-v3.html",
      "icon.png"
    ]
  }
}